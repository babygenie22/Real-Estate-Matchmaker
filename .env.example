# PostgreSQL connection string (required)
# Example: postgresql://user:password@localhost:5432/homematch
DATABASE_URL=postgresql://postgres:password@localhost:5432/homematch

# Secret used to sign session cookies — change this to a long random string in production
SESSION_SECRET=change-me-to-a-long-random-secret

# Port to listen on (optional, defaults to 5000)
# PORT=5000

# ── Google Places API (New) ─────────────────────────────────────────────────
# Used for searching real estate agencies near a location.
# Enable "Places API (New)" in Google Cloud Console → APIs & Services.
# Free tier: $200/month credit (~5,000 nearby searches/month free)
# Get key: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=

# ── RentCast API ────────────────────────────────────────────────────────────
# Used for local market stats (median price, days on market, price/sqft).
# Free tier: 50 API calls/month. Falls back to mock data if not set.
# Get key: https://app.rentcast.io/app/api-access
RENTCAST_API_KEY=

# ── Resend (Transactional Email) ─────────────────────────────────────────────
# Used for match notifications, booking confirmations, agent welcome emails.
# Free tier: 100 emails/day. Emails are silently skipped if not set.
# Get key: https://resend.com
RESEND_API_KEY=
FROM_EMAIL=HomeMatch <noreply@homematch.app>

# ── App URL ───────────────────────────────────────────────────────────────────
# Used in email templates for "View →" links. Set to your public domain in prod.
APP_URL=http://localhost:3001
