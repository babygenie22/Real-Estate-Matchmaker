{
  "expo": {
    "name": "HomeMatch",
    "slug": "homematch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "homematch",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.homematch.app",
      "infoPlist": {
        "NSCameraUsageDescription": "HomeMatch uses your camera to upload a profile photo.",
        "NSPhotoLibraryUsageDescription": "HomeMatch accesses your photo library to upload a profile photo.",
        "NSLocationWhenInUseUsageDescription": "HomeMatch uses your location to find agents near you."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.homematch.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2563eb"
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://localhost:3001",
      "router": {
        "origin": false
      }
    }
  }
}
